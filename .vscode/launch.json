
{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Depurar con Chrome en XAMPP",
            "url": "http://localhost/prueba 1",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "trace": true,
            "sourceMapPathOverrides": {
                "webpack:///./~/*": "${webRoot}/node_modules/*",
                "webpack:////*": "/*",
                "webpack:///?:*/*": "${webRoot}/*"
            }
        }
    ]
} 